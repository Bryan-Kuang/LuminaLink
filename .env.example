# LuminaLink Environment Configuration

# ============================================
# AI Configuration
# ============================================

# OpenAI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here

# AI Model (gpt-4o recommended)
OPENAI_MODEL=gpt-4o

# ============================================
# TTS Configuration
# ============================================

# TTS Engine: edge, gtts, or pyttsx3
TTS_ENGINE=edge

# Voice selection
# English voices: en-US-AriaNeural, en-US-GuyNeural, en-GB-SoniaNeural
# Chinese voices: zh-CN-XiaoxiaoNeural, zh-CN-YunxiNeural
TTS_VOICE=en-US-AriaNeural

# Speech rate (1.0 = normal, 1.2 = faster, 0.8 = slower)
TTS_SPEED=1.0

# ============================================
# Narration Configuration
# ============================================

# Minimum interval between narrations (seconds)
NARRATION_INTERVAL=5

# Maximum narration length (characters)
NARRATION_MAX_LENGTH=250

# Silence threshold for dialogue detection (dB)
SILENCE_THRESHOLD=-35

# ============================================
# Video Configuration
# ============================================

# Frame extraction interval (seconds)
KEYFRAME_INTERVAL=1.0

# ============================================
# Face Recognition (optional)
# ============================================

# Enable face recognition
FACE_RECOGNITION_ENABLED=false

# Face match tolerance (0.0-1.0, lower = stricter)
FACE_MATCH_TOLERANCE=0.6
